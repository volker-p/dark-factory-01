    "graph_source": "digraph ImplementSpec {\n    graph [\n        goal=\"Implement the spec at {{ inputs.spec_path }} in the target repository and open a pull request\"\n        rankdir=LR\n    ]\n\n    start [shape=Mdiamond, label=\"Start\"]\n    exit  [shape=Msquare,  label=\"Exit\"]\n\n    // Read spec, clone target repo, write plan.md and run-tests.sh\n    plan [\n        label=\"Plan\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/run-plan-agent.sh\"\n        timeout=\"300s\"\n    ]\n\n    // Human reviews plan before any code is written\n    gate_plan [shape=hexagon, label=\"Approve Plan\"]\n\n    // Implement plan.md in target-repo/\n    implement [\n        label=\"Implement\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/run-implement-agent.sh\"\n        timeout=\"900s\"\n        max_visits=4\n    ]\n\n    // Run the build and test suite written by the plan agent\n    test [\n        label=\"Test\"\n        shape=parallelogram\n        script=\"bash run-tests.sh 2>&1 | tee test-output.txt; exit ${PIPESTATUS[0]}\"\n    ]\n\n    // \"Pass\" (Yes) requires the script to exit 0, which only happens when every single test\n    // succeeds — including all scenario tests (e.g. SimulationPathFinder scenario suite).\n    // One failing test = non-zero exit = \"Fix\" branch. There is no partial pass.\n    test_gate [shape=diamond, label=\"Tests pass?\\n(ALL tests must succeed)\"]\n\n    // Fix failures — reads test-output.txt and code directly\n    fix [\n        label=\"Fix\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/run-fix-agent.sh\"\n        timeout=\"600s\"\n        max_visits=3\n    ]\n\n    // Independent model reviews implementation against spec\n    review [\n        label=\"Review\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/run-review-agent.sh\"\n        timeout=\"300s\"\n    ]\n\n    // Human sees satisfaction report, approves or requests rework\n    gate_pr [shape=hexagon, label=\"Approve PR\"]\n\n    // Commit, push branch to target repo, open PR\n    push_pr [\n        label=\"Push PR\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/push-pr.sh\"\n    ]\n\n    // Squash-merge the PR into master via GitHub API\n    merge_pr [\n        label=\"Merge PR\"\n        shape=parallelogram\n        script=\"bash .fabro/workflows/implement-spec/scripts/merge-pr.sh\"\n    ]\n\n    start    -> plan      -> gate_plan\n    gate_plan -> implement [label=\"[A] Approve\"]\n    gate_plan -> plan      [label=\"[R] Revise\"]\n    implement -> test      -> test_gate\n    test_gate -> review    [label=\"Pass\",  condition=\"outcome=succeeded\"]\n    test_gate -> fix       [label=\"Fix\"]\n    fix       -> test\n    review    -> gate_pr\n    gate_pr   -> push_pr   [label=\"[M] Merge\"]\n    gate_pr   -> implement [label=\"[R] Rework\"]\n    push_pr   -> merge_pr  -> exit\n}\n",
